# Supabase (optional — used for bed board when Prisma API is not enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Prisma REST API (bed board + inventory). When set (including empty), the app uses /api on this origin.
# Dev: add VITE_API_URL= to .env so requests go to Vite proxy → server on port 3001 (run npm run dev:api).
# Production: VITE_API_URL=https://your-api.example.com
# VITE_API_URL=

# PostgreSQL for Prisma (server only — use Supabase connection string later)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/hospi_track?schema=public

# BedPulse AI service (FastAPI) — capacity forecast, weekday stats
# Dev: omit VITE_AI_SERVICE_URL to use Vite proxy /bedpulse → 127.0.0.1:8001 (run python main.py in ai_service).
# Production / preview without proxy:
# VITE_AI_SERVICE_URL=https://your-bedpulse-api.example.com
# VITE_DEMO_WARD_ID=00000000-0000-0000-0000-000000000001
